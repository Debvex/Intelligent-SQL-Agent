# =====================
# Database
# =====================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=sqlagent
DB_USER=readonly_user
DB_PASSWORD=readonly_pass

# =====================
# LLM / Ollama
# =====================
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# =====================
# Agent hard limits
# =====================
MAX_ITERATIONS=10
MAX_RETRIES=2
MAX_RESULT_ROWS=100
QUERY_TIMEOUT_SECONDS=30
CONVERSATION_HISTORY_DEPTH=20

# =====================
# Caching
# =====================
CACHE_MAX_SIZE=128

# =====================
# LangSmith (optional — leave empty to disable)
# =====================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=sql-agent

# =====================
# FastAPI
# =====================
API_HOST=0.0.0.0
API_PORT=8000